# Backend dev environment – matches the NodePort services from values.dev.yml.
# Usage:
#   cp backend/.env.dev backend/.env
#   cd backend && air
#
# Or export inline: set -a; source backend/.env.dev; set +a; cd backend && air

DATABASE_URL="host=localhost port=30432 user=dcs password=dcs dbname=dcs sslmode=disable"

# Dev bootstrap issuer. Replace with your deployed Hydra issuer URL as needed.
OIDC_ISSUER_URL=http://localhost:5173
OIDC_CLIENT_ID=dcs-client
OIDC_CLIENT_SECRET=dcs-secret
OIDC_REDIRECT_URI=http://localhost:5173/api/auth/callback
OIDC_LOGOUT_REDIRECT_URI=http://localhost:5173/api/auth/logout-complete

# Hydra admin API. Reachable from the host via the NodePort exposed in
# deployment/helm/values.dev.yml (hydra.service.adminNodePort). Port 4445 is
# the in-cluster admin port and is NOT reachable from the host.
HYDRA_ADMIN_URL=http://localhost:30085

NATS_URL=nats://localhost:30422

DCS_API_PATH=/api
DCS_UI_PATH=/ui/

FEDERATED_CATALOGUE_API_URL=http://localhost:30081

# Public issuer base URL exposed to wallets. In local dev this should point to
# the ingress/proxy route (Vite), not direct service NodePorts.
OCM_W_ISSUER_URL=http://localhost:31795
OCM_W_PUBLIC_ISSUER_URL=http://localhost:5173
OCM_W_TENANT_ID=tenant_space
OCM_W_CREDENTIAL_CONFIGURATION_ID=DCSRoleCredential

# Signer service used by wallet authentication request signing.
OCM_W_SIGNER_URL=http://localhost:30190
OCM_W_SIGNER_NAMESPACE=tenant_space
OCM_W_SIGNER_GROUP=
OCM_W_SIGNER_KEY=signerkey

# DID advertised as the verifier client_id inside the OID4VP request_object.
# CV puts the value of the x-did header verbatim into the JWT client_id claim;
# wallets use it as the audience of the verifiable presentation.
OCM_W_PRESENTATION_DID=did:web:dcs.local

# CV service exposed via NodePort in deployment/helm/values.dev.yml
# If Kubernetes reassigns this port, update from:
#   kubectl -n default get svc credential-verification-service -o jsonpath='{.spec.ports[0].nodePort}'
CREDENTIAL_VERIFICATION_URL=http://localhost:32035

# Public host advertised to wallets inside the OID4VP request_object's response_uri.
# CV builds response_uri from the incoming HTTP Host header, so the backend overrides it.
# In dev the wallet reaches the CV proof endpoint via the Vite proxy on localhost:5173.
PRESENTATION_PUBLIC_HOST=localhost:5173